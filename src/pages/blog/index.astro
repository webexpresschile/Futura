---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

// This is a minimal blog index that won't break if content is missing
// The repository seems to have some broken mdx files, we provide a placeholder
---

<Layout title="Blog - Futura Agencia Digital">
  <Navbar />
  
  <div class="page-header text-center" style="padding: 180px 0 80px 0; background-color: var(--color-bg-light);">
    <div class="container">
      <h1 class="text-gradient" style="font-size: 3.5rem; margin-bottom: 1rem;">Nuestro Blog</h1>
      <p style="font-size: 1.25rem;">Artículos, tendencias y recursos sobre marketing, diseño y tecnología.</p>
    </div>
  </div>
  
  <section class="blog-list" style="padding: 5rem 0; min-height: 50vh;">
    <div class="container" style="max-width: 900px;">
      
      <article class="blog-card" style="background: white; border-radius: var(--radius-md); padding: 2rem; margin-bottom: 2rem; box-shadow: var(--shadow-sm); border: 1px solid rgba(0,0,0,0.05); transition: transform 0.3s ease;">
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem;">
          <a href="/blog/tendencias-marketing-digital-2026" style="color: var(--color-dark);">Tendencias de Marketing Digital 2026</a>
        </h2>
        <div style="font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 1rem;">
          Renata • 15 de Abril, 2026
        </div>
        <p style="color: var(--color-text); margin-bottom: 1.5rem;">Descubre las 5 tendencias de marketing digital que están definiendo 2026: IA, video corto, micro-influencers, SEO semántico y automatización.</p>
        <a href="/blog/tendencias-marketing-digital-2026" style="color: var(--color-primary); font-weight: 600;">Leer artículo &rarr;</a>
      </article>

    </div>
  </section>
  
  <Footer />
</Layout>
