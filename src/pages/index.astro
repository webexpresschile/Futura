---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Astro.layout title="Futura Agencia Digital - DiseĂ±o Web, Citae IA y Tienda Nube">
  <Navbar />
  
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <h1 class="hero-title scroll-reveal">
        Transforma tu Negocio con <span class="text-gradient">DiseĂ±o Web, CITAE IA y E-commerce</span>
      </h1>
      <p class="hero-subtitle scroll-reveal">
        Agencia digital especializada en crear sitios web profesionales, automatizar procesos con inteligencia artificial y lanzar tiendas en lĂ­nea listas para vender.
      </p>
      <div class="hero-actions scroll-reveal">
        <a href="/contacto" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1.125rem;">Solicitar CotizaciĂłn Gratis</a>
        <a href="/servicios" class="btn btn-secondary">Ver Servicios</a>
      </div>
      <div class="hero-stats scroll-reveal">
        <div class="stat">
          <span class="stat-number">500+</span>
          <span class="stat-label">Proyectos Exitosos</span>
        </div>
        <div class="stat">
          <span class="stat-number">98%</span>
          <span class="stat-label">Clientes Satisfechos</span>
        </div>
        <div class="stat">
          <span class="stat-number">24/7</span>
          <span class="stat-label">Soporte Dedicado</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- ProblemĂˇtica Section -->
  <section class="problems-section">
    <div class="container">
      <div class="section-header text-center scroll-reveal">
        <h2>ÂŻPor quĂ© matas llevas tu negocio?</h2>
        <p class="section-subtitle">Estos son los 3 problemas mĂˇs comunes que efrentan los empresarios digitales hoy.</p>
      </div>
      
      <div class="problem-grid">
        <!-- Problema 1 -->
        <div class="problem-card scroll-reveal">
          <div class="problem-icon">Âź</div>
          <h3>"1ro aparezco en los buscadores"</h3>
          <p class="problem-desc">Tu negocio no aparece en Google cuando tercero te busca. Pierdes 80% de clientes potenciales que nunca te encuentran.</p>
          <div class="solucion">
            <h4>âś… SoluciĂłn: DiseĂ±o Web Profesional</h4>
            <p>Un sitio web optimizado para SEO te posiciona en los primeros resultados de Google.</p>
            <a href="/servicios#diseno-web" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.875rem;">Ver Planes</a>
          </div>
        </div>
        
        <!-- Problema 2 -->
        <div class="problem-card scroll-reveal">
          <div class="problem-icon">âś…</div>
          <h3>"Pierden clientes por WhatsApp"</h3>
          <p class="problem-desc">Clientes que cotizan por WhatsApp y nunca respondes. No estĂˇs 24/7, y los clientes se cansan y se van con la competencia.</p>
          <div class="solucion">
            <h4>Âź SoluciĂłn: CITAE IA</h4>
            <p>Sistema todo en uno: Web + Calendarios + Agentes IA para agendamiento y CRM para seguimiento.</p>
            <a href="/servicios#citae" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.875rem;">Conocer CITAE</a>
          </div>
        </div>
        
        <!-- Problema 3 -->
        <div class="problem-card scroll-reveal">
          <div class="problem-icon">đźš€</div>
          <h3>"Quieren vender en linea pero no tienen tienda"</h3>
          <p class="problem-desc">Sabs que podrĂ­as estar vendiendo 24/7 sin limites geogrĂˇficos, pero no sabes c3mo empezar o no tienes tiempo para gestionarlo.</p>
          <div class="solucion">
            <h4>âś… SoluciĂłn: Tienda Nube</h4>
            <p>Tu tienda en lĂ­nea profesional, configurada de principio a fin, con todos los mĂ©todos de pago y envĂ­os.</p>
            <a href="/servicios#tienda-nube" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.875rem;">Ver Planes</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Servicios Section -->
  <section class="services-section" id="servicios">
    <div class="container">
      <div class="section-header text-center scroll-reveal">
        <h2>Nuestros Servicios</h2>
        <p>Coge de la primera consulta gratuita y descubre cĂłmo podemos ayudarte.</p>
      </div>
      
      <div class="services-grid">
        <!-- Servicio 1 - DiseĆ±o Web -->
        <div class="service-card scroll-reveal">
          <div class="service-icon" style="background: rgba(0, 102, 204, 0.1); color: var(--color-primary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x="8" y="21" x2="16" y2="21"></line><line x="12" y="17" x2="12" y2="21"></line></svg>
          </div>
          <h3>DiseĂ±o Web</h3>
          <p>Sitios web para empresas de todos los tamaĹos. Desde landing pages hasta sitios corporativos.</p>
          <div class="service-pricing">
            <div class="price-card">
              <span class="price-label">Emprendedores</span>
              <span class="price">$499 USD</span>
              <span class="price-descr">One Page</span>
            </div>
            <div class="price-card">
              <span class="price-label">Corporativos</span>
              <span class="price">$999 USD</span>
              <span class="price-descr">5+ pĂˇginas</span>
            </div>
            <a href="/contacto" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.5rem 1rem; font-size: 0.875rem;">Solicitar Demo</a>
          </div>
        </div>
        
        <!-- Servicio 2 - CITAE IA -->
        <div class="service-card scroll-reveal">
          <div class="service-icon" style="background: rgba(0, 212, 170, 0.1); color: var(--color-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09a1.65 1.65 0 0 0 4.6-9 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33 9 1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.55 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.55 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.55 1"></path></svg>
          </div>
          <h3>CITAE IA</h3>
          <p>Sistema todo en uno para automatizar la atenciĂłn al cliente. Incluye web, calendarios, IA y CRM.</p>
          <div class="service-pricing">
            <div class="price-card">
              <span class="price-label">BĂˇsico</span>
              <span class="price">$799 USD</span>
              <span class="price-descr">Web + Chatbot</span>
            </div>
            <div class="price-card">
              <span class="price-label">Pro</span>
              <span class="price">$1,499 USD</span>
              <span class="price-descr">Calendarios + CRM</span>
            </div>
            <a href="/contacto" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.5rem 1rem; font-size: 0.875rem;">Agendar ConsultorĂ­a</a>
          </div>
        </div>
        
        <!-- Servicio 3 - Tienda Nube -->
        <div class="service-card scroll-reveal">
          <div class="service-icon" style="background: rgba(26, 26, 46, 0.1); color: var(--color-dark);">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          </div>
          <h3>Tienda Nube</h3>
          <p>Tu tienda en lĂ­nea profesional lista para vender. ConfiguraciĂłn completa, diseĆ±o personalizado y todas las herramientas.</p>
          <div class="service-pricing">
            <div class="price-card">
              <span class="price-label">BĂˇsico</span>
              <span class="price">$699 USD</span>
              <span class="price-descr">DiseĂ±o estĂˇndar</span>
            </div>
            <div class="price-card">
              <span class="price-label">Pro</span>
              <span class="price">$999 USD</span>
              <span class="price-descr">DiseĂ±o personalizado</span>
            </div>
            <a href="/contacto" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.5rem 1rem; font-size: 0.875rem;">Ver Planes</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container text-center">
      <h2 style="color: white; margin-bottom: 1.5rem;">Â©Listo para digitalizar tu negocio con Ă©xito?</h2>
      <p style="color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto 2.5rem auto; font-size: 1.125rem;">Agenda una llamada gratuita de 15 minutos y te aseguramos que encontrarĂˇs la soluciĂłn ideal para tu negocio.</p>
      <a href="/contacto" class="btn btn-secondary" style="font-size: 1.25rem; padding: 1rem 2.5rem; border: none; color: var(--color-primary);">Agendar Llamada Gratis</a>
    </div>
  </section>
  
  <Footer />
</Astroclayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 140px 0 80 0;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: linear-gradient(135deg, #F8F9FA 0%, #F0F5FF 50%, #E6F4F5 100%);
  }
  
  .hero-bg {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(0, 102, 204, 0.08) 0%, rgba(0, 212, 170, 0.05) 30%, rgba(255,255,255,0) 60%);
    z-index: -1;
    animation: rotate 60s linear infinite;
  }
  
  @keyframes rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  .hero-content {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  
  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 700px;
    margin: 0 auto 2.5rem auto;
    line-height: 1.7;
  }
  
  .hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  
  .hero-stats {
    display: flex;
    gap: 3rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .stat {
    text-align: center;
    padding: 1.5rem;
    background: rgba(255,255,255,0.5);
    border-radius: 12px;
    min-width: 140px;
  }
  
  .stat-number {
    display: block;
    font-size: 2.5bem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }
  
  .stat-label {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
  
  /* Problemas Section */
  .problems-section {
    background: linear-gradient(135deg, #FFFFFF 0%, #F5F7F9 100%);
    padding: 6rem 0;
  }
  
  .section-header h2 {
    margin-bottom: 0.5rem;
  }
  
  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }
  
  .problem-card {
    background: var(--color-bg);
    border-radius: var(--radius-md);
    padding: 2rem;
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
  }
  
  .problem-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }
  
  .problem-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  
  .problem-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    color: var(--color-dark);
  }
  
  .problem-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  
  .solucion {
    background: rgba(0, 102, 204, 0.05);
    border-radius: 8px;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }
  
  .solucion h4 {
    font-size: 1.125rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  
  .solucion p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  
  /* Services */
  .services-section {
    background-color: var(--color-bg-light);
    padding: 6rem 0;
  }
  
  .section-header {
    margin-bottom: 4rem;
  }
  
  .section-header h2 {
    margin-bottom: 0.5rem;
  }
  
  .section-header p {
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
  }
  
  .service-card {
    background: var(--color-bg);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
    border: 1px solid rgba(0,0,0,0.03);
  }
  
  .service-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-lg);
  }
  
  .service-icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  
  .service-pricing {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0,0,0,0.05);
  }
  
  .price-card {
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1rem;
    transition: all 0.3s ease;
  }
  
  .price-card:hover {
    border-color: var(--color-primary);
    background: rgba(0, 102, 204, 0.05);
  }
  
  .price-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  
  .price {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }
  
  .price-descr {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  
  /* CTA */
  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, #004d99 100%);
    padding: 6rem 0;
    margin-top: auto;
  }
  
  /* Scroll Animations */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 120px 0 60px 0;
    }
    
    .hero-stats {
      flex-direction: column;
      gap: 1rem;
    }
    
    .stat {
      min-width: auto;
    }
    
    .services-grid, .problem-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  
  document.querySelectorAll('.scroll-reveal').forEach(el => {
    observer.observe(el);
  });
</script>