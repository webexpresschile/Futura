<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 140px 0 80 0;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: linear-gradient(135deg, #F8F9FA 0%, #F0F5FF 50%, #E6F4F5 100%);
  }
  
  .hero-bg {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(0, 102, 204, 0.08) 0%, rgba(0, 212, 170, 0.05) 30%, rgba(255,255,255,0) 60%);
    z-index: -1;
    animation: rotate 60s linear infinite;
  }
  
  @keyframes rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  .hero-content {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  
  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 700px;
    margin: 0 auto 2.5rem auto;
    line-height: 1.7;
  }
  
  .hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  
  .hero-stats {
    display: flex;
    gap: 3rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .stat {
    text-align: center;
    padding: 1.5rem;
    background: rgba(255,255,255,0.5);
    border-radius: 12px;
    min-width: 140px;
  }
  
  .stat-number {
    display: block;
    font-size: 2.5bem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }
  
  .stat-label {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
  
  /* Services */
  .services-section {
    background-color: var(--color-bg-light);
    padding: 6rem 0;
  }
  
  .section-header {
    margin-bottom: 4rem;
  }
  
  .section-header h2 {
    margin-bottom: 0.5rem;
  }
  
  .section-header p {
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
  }
  
  .service-card {
    background: var(--color-bg);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
    border: 1px solid rgba(0,0,0,0.03);
  }
  
  .service-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-lg);
  }
  
  .service-icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  
  .service-features {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }
  
  .service-features li {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    padding-left: 0.25rem;
  }
  
  .service-cta {
    margin-top: 1.5rem;
    pt-1.5rem;
    border-top: 1px solid rgba(0,0,0,0.05);
  }
  
  .price {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  
  /* Features */
  .features-section {
    padding: 6rem 0;
  }
  
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }
  
  .feature-card {
    text-align: center;
    padding: 2rem;
  }
  
  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  
  .feature-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  
  .feature-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  
  /* CTA */
  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, #004d99 100%);
    padding: 6rem 0;
    margin-top: auto;
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 120px 0 60px 0;
    }
    
    .hero-stats {
      flex-direction: column;
      gap: 1rem;
    }
    
    .stat {
      min-width: auto;
    }
    
    .services-grid, .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>