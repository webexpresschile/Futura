---
---
<section class="faq-section">
  <div class="container container-narrow text-center" style="margin-bottom: 4rem;">
    <h2>RESPUESTAS RÁPIDAS</h2>
  </div>
  
  <div class="container container-narrow">
    <div class="faq-list gs-faq">
      <!-- FAQ 1 -->
      <div class="brutalist-card faq-item">
        <button class="faq-question">
          <span>¿Cuánto tarda la instalación?</span>
          <span class="icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="answer-content">
            <p>De 48 a 72 horas. Instalamos, configuramos y te lo entregamos listo para facturar.</p>
          </div>
        </div>
      </div>
      
      <!-- FAQ 2 -->
      <div class="brutalist-card faq-item">
        <button class="faq-question">
          <span>¿Necesito saber de código o computación?</span>
          <span class="icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="answer-content">
            <p>Cero. El panel de gestión está hecho a prueba de balas, diseñado para mecánicos, no para hackers.</p>
          </div>
        </div>
      </div>
      
      <!-- FAQ 3 -->
      <div class="brutalist-card faq-item">
        <button class="faq-question">
          <span>¿Y los que escriben un domingo a la noche?</span>
          <span class="icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="answer-content">
            <p>El bot atiende de madrugada. Agendará la cita confirmada para tu próximo día hábil. No pierdes a nadie.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  if (typeof document !== 'undefined') {
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
      const btn = item.querySelector('.faq-question');
      btn.addEventListener('click', () => {
        item.classList.toggle('active');
        const icon = btn.querySelector('.icon');
        if (item.classList.contains('active')) {
          icon.textContent = '-';
        } else {
          icon.textContent = '+';
        }
      });
    });
  }
</script>

<style>
  .faq-section {
    background-color: var(--color-surface-alt);
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .faq-item {
    padding: 0;
  }
  .faq-question {
    width: 100%;
    text-align: left;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--color-primary);
  }
  .faq-question .icon {
    font-size: 2rem;
    line-height: 1;
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    background: var(--color-bg);
  }
  .faq-item.active .faq-answer {
    max-height: 300px;
    border-top: var(--border-width) solid var(--color-border);
  }
  .answer-content {
    padding: 1.5rem 2rem;
  }
  .answer-content p {
    font-weight: 600;
    margin: 0;
  }
</style>
