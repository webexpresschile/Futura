---
---
<section class="problem-section" id="funciones">
  <div class="container container-narrow">
    <div class="problem-header text-center gs-fade">
      <div class="badge-accent">EL PROBLEMA</div>
      <h2>¿Cuánto dinero pierdes por no responder a tiempo?</h2>
    </div>
    
    <div class="problem-cards">
      <div class="brutalist-card gs-card">
        <div class="icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
        <h3>Citas Perdidas</h3>
        <p>Los clientes cotizan en varios lados y agendan con el primero que responde.</p>
      </div>
      
      <div class="brutalist-card gs-card card-blue">
        <div class="icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        </div>
        <h3>Horas Desperdiciadas</h3>
        <p>Estar pegado al celular respondiendo mensajes te quita foco del taller.</p>
      </div>

      <div class="brutalist-card gs-card">
        <div class="icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
        </div>
        <h3>Sin Recordatorios</h3>
        <p>Alumnos olvidadizos que no llegan a su cita son espacio perdido en tu agenda.</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);
    gsap.from(".problem-cards .gs-card", {
      scrollTrigger: { trigger: ".problem-section", start: "top 80%" },
      y: 20, opacity: 0, duration: 0.5, stagger: 0.2
    });
  }
</script>

<style>
  .problem-section {
    background-color: #FEF08A; /* Intense Yellow */
    border-top: var(--border-width) solid var(--color-border);
  }
  .badge-accent {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    font-weight: 800;
    padding: 0.5rem 1rem;
    margin-bottom: 1rem;
    transform: rotate(-2deg);
    border: 2px solid white;
    box-shadow: 4px 4px 0px var(--color-primary);
  }
  .problem-header {
    margin-bottom: var(--space-8);
  }
  .problem-header h2 {
    color: var(--color-primary);
  }
  .problem-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .problem-cards .brutalist-card {
    padding: 2rem;
  }
  .icon {
    width: 60px;
    height: 60px;
    background: var(--color-bg);
    border: var(--border-width) solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    box-shadow: 3px 3px 0px var(--color-border);
    color: var(--color-accent);
  }
  .card-blue {
    background-color: var(--color-accent);
    color: white;
  }
  .card-blue p {
    color: white;
  }
  .card-blue .icon {
    color: white;
    background: var(--color-primary);
  }

  @media (max-width: 900px) {
    .problem-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
