---
---
<section class="solution-section">
  <div class="container">
    <div class="text-center gs-sol-header">
      <div class="badge">LA SOLUCIÓN</div>
      <h2>Tu taller en piloto automático</h2>
    </div>
    
    <div class="steps-grid">
      <div class="brutalist-card step gs-step">
        <div class="step-number">1</div>
        <h3>El cliente escribe</h3>
        <p>Tu cliente envía un mensaje a tu WhatsApp preguntando por reservas o servicios. Sin instalación de apps.</p>
      </div>
      
      <div class="step-arrow gs-step">→</div>
      
      <div class="brutalist-card step gs-step card-blue">
        <div class="step-number">2</div>
        <h3>El Bot responde</h3>
        <p>El bot cruza datos con tu calendario, ofrece horarios reales, confirma y agenda automáticamente.</p>
      </div>
      
      <div class="step-arrow gs-step">→</div>
      
      <div class="brutalist-card step gs-step">
        <div class="step-number">3</div>
        <h3>Taller asegurado</h3>
        <p>El sistema envía un mensaje recordatorio horas antes. Si no asiste, suelta la hora.</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);
    gsap.from(".steps-grid .gs-step", {
      scrollTrigger: { trigger: ".solution-section", start: "top 80%" },
      y: 20, opacity: 0, duration: 0.5, stagger: 0.2
    });
  }
</script>

<style>
  .solution-section {
    background-color: var(--color-bg);
  }
  .gs-sol-header {
    margin-bottom: var(--space-8);
  }
  .gs-sol-header h2 {
    margin-top: 1rem;
  }
  .steps-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
  }
  .step {
    flex: 1;
    position: relative;
    padding-top: 3rem;
  }
  .step-number {
    position: absolute;
    top: -24px;
    left: -24px;
    width: 60px;
    height: 60px;
    background-color: var(--color-accent);
    color: white;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: var(--border-width) solid var(--color-border);
    box-shadow: 4px 4px 0px #000;
  }
  .card-blue {
    background: var(--color-accent);
    color: white;
  }
  .card-blue p { color: white; }
  .card-blue .step-number {
    background: #FEF08A;
    color: black;
  }
  .step-arrow {
    font-size: 4rem;
    font-weight: 900;
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .steps-grid {
      flex-direction: column;
      gap: var(--space-6);
    }
    .step-arrow {
      transform: rotate(90deg);
    }
    .step-number {
      top: -20px;
      left: 20px;
    }
  }
</style>
