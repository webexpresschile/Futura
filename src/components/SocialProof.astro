<section class="social-proof">
  <div class="container text-center">
    <p class="sp-text">USADO POR TALLERES LÍDERES EN SANTIAGO, PROVIDENCIA Y LAS CONDES</p>
    <div class="marquee-container">
      <div class="marquee">
        <!-- Replicating content for continuous scrolling -->
        <span>TALLER TITANIUM</span>
        <span class="dot">★</span>
        <span>AUTOSERVICIO PRO</span>
        <span class="dot">★</span>
        <span>GARAGE CENTRAL</span>
        <span class="dot">★</span>
        <span>MOTOR EXPERTS</span>
        <span class="dot">★</span>
        <span>TALLER TITANIUM</span>
        <span class="dot">★</span>
        <span>AUTOSERVICIO PRO</span>
        <span class="dot">★</span>
        <span>GARAGE CENTRAL</span>
        <span class="dot">★</span>
        <span>MOTOR EXPERTS</span>
      </div>
    </div>
  </div>
</section>

<style>
  .social-proof {
    padding: var(--space-4) 0;
    border-bottom: var(--border-width) solid var(--color-border);
    background-color: var(--color-accent);
  }
  .sp-text {
    font-size: 1rem;
    font-weight: 800;
    color: white;
    margin-bottom: var(--space-4);
    text-shadow: 2px 2px 0px #000;
  }
  .marquee-container {
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    width: 100%;
    background: white;
    padding: 1rem 0;
    border: var(--border-width) solid var(--color-border);
    box-shadow: 4px 4px 0px #000;
    transform: rotate(1deg);
  }
  .marquee {
    display: inline-block;
    animation: marquee 20s linear infinite;
  }
  .marquee span {
    font-size: 1.5rem;
    font-family: var(--font-display);
    font-weight: 900;
    color: var(--color-primary);
    margin: 0 var(--space-4);
    text-transform: uppercase;
  }
  .marquee .dot {
    color: var(--color-accent);
    font-size: 1.5rem;
  }
  
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }
</style>
