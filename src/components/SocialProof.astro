<section class="social-proof">
  <div class="sp-header text-center">
    <p class="sp-text">USADO POR TALLERES LÍDERES EN SANTIAGO, PROVIDENCIA Y LAS CONDES</p>
  </div>
  <div class="marquee-container">
    <div class="marquee">
      <!-- Replicating content for continuous scrolling -->
      <span>TALLER TITANIUM</span>
      <span class="dot">★</span>
      <span>AUTOSERVICIO PRO</span>
      <span class="dot">★</span>
      <span>GARAGE CENTRAL</span>
      <span class="dot">★</span>
      <span>MOTOR EXPERTS</span>
      <span class="dot">★</span>
      <span>TALLER TITANIUM</span>
      <span class="dot">★</span>
      <span>AUTOSERVICIO PRO</span>
      <span class="dot">★</span>
      <span>GARAGE CENTRAL</span>
      <span class="dot">★</span>
      <span>MOTOR EXPERTS</span>
    </div>
  </div>
</section>

<style>
  .social-proof {
    padding: 3rem 0 2rem;
    border-top: var(--border-width) solid var(--color-border);
    border-bottom: var(--border-width) solid var(--color-border);
    background-color: var(--color-accent);
    overflow: hidden;
  }
  .sp-header {
    padding: 0 var(--space-4);
    margin-bottom: var(--space-6);
  }
  .sp-text {
    font-size: 0.85rem;
    font-weight: 800;
    color: #000000;
    letter-spacing: 0.1em;
    margin: 0;
  }
  .marquee-container {
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    width: 100%;
    background: #000000;
    padding: 1.25rem 0;
    border-top: 3px solid #000000;
    border-bottom: 3px solid #000000;
  }
  .marquee {
    display: inline-block;
    animation: marquee 20s linear infinite;
  }
  .marquee span {
    font-size: 1.5rem;
    font-family: var(--font-display);
    font-weight: 900;
    color: #ffffff;
    margin: 0 var(--space-4);
    text-transform: uppercase;
  }
  .marquee .dot {
    color: var(--color-accent);
    font-size: 1.5rem;
  }
  
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }
</style>
