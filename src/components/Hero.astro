---
---
<section class="hero">
  <div class="container hero-container">
    <div class="hero-content gs-reveal">
      <div class="badge">Automatización IA</div>
      <h1 id="dynamic-title">TU TALLER AGENDA SOLO.</h1>
      <p id="dynamic-desc">Tus clientes agendan sus horas a través de WhatsApp automáticamente, 24/7, sin esperas. Libérate del teléfono y enfócate en tu negocio.</p>
      <div class="hero-ctas">
        <a href="#demo-vivo" class="btn btn-primary gs-btn">Ver demo en vivo</a>
        <a href="#como-funciona" class="btn btn-secondary gs-btn">Ver cómo funciona</a>
      </div>
    </div>
    
    <div class="hero-visual gs-reveal-right">
      <div class="phone-mockup">
        <div class="wa-header">
          <div class="wa-avatar"></div>
          <div class="wa-info">
            <strong id="dynamic-name">Taller AutoTotal</strong>
            <span>en línea</span>
          </div>
        </div>
        <div class="wa-chat" id="dynamic-chat">
          <div class="msg client">Hola, necesito hora para revisión general.</div>
          <div class="msg bot">¡Hola! Soy el asistente virtual de AutoTotal 🚗<br><br>Horarios disponibles:<br>1️⃣ Mañana 10:00<br>2️⃣ Mañana 15:30<br><br>Responde con el número.</div>
          <div class="msg client">1</div>
          <div class="msg bot">¡Perfecto! Agenda confirmada ✅.<br>Te recordaremos 2 horas antes.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    gsap.from(".badge", { opacity: 0, y: 20, duration: 0.5, delay: 0.1 });
    gsap.from("h1", { opacity: 0, y: 20, duration: 0.5, delay: 0.2 });
    gsap.from(".hero-content p", { opacity: 0, y: 20, duration: 0.5, delay: 0.3 });
    gsap.from(".hero-ctas", { opacity: 0, y: 20, duration: 0.5, delay: 0.4 });
    gsap.from(".phone-mockup", { opacity: 0, x: 20, duration: 0.5, delay: 0.5 });

    // Lógica de rotación de nichos
    const niches = [
      {
        title: "TU TALLER AGENDA SOLO.",
        desc: "Tus clientes agendan sus horas automáticamente, 24/7. Libérate del teléfono y enfócate en los autos.",
        name: "Taller AutoTotal",
        chat: `<div class="msg client">Hola, necesito hora para revisión general.</div>
               <div class="msg bot">¡Hola! Soy el asistente de AutoTotal 🚗<br><br>Horarios:<br>1️⃣ Mañana 10:00<br>2️⃣ Mañana 15:30<br><br>Responde con el número.</div>
               <div class="msg client">1</div>
               <div class="msg bot">¡Agenda confirmada ✅!<br>Te recordaremos 2 horas antes.</div>`
      },
      {
        title: "TU BARBERÍA SE LLENA SOLA.",
        desc: "Deja de contestar WhatsApp mientras cortas pelo. El bot agenda, confirma y reactiva a tus clientes.",
        name: "Barbería Elite",
        chat: `<div class="msg client">¿Tienen espacio para un corte y barba hoy?</div>
               <div class="msg bot">¡Bienvenido a Barbería Elite! ✂️<br><br>Hoy tenemos:<br>1️⃣ 17:00 (Andrés)<br>2️⃣ 18:30 (Javi)<br><br>¿Con quién te agendo?</div>
               <div class="msg client">Con Andrés</div>
               <div class="msg bot">¡Listo! Quedas agendado a las 17:00 con Andrés. 💈</div>`
      },
      {
        title: "TU SALÓN DE BELLEZA BRILLA.",
        desc: "Automatiza tus citas de uñas, cabello y maquillaje. Tus clientas aman la respuesta inmediata.",
        name: "Glow Salón",
        chat: `<div class="msg client">Hola, me quiero hacer las uñas.</div>
               <div class="msg bot">¡Hola! En Glow Salón te esperamos 💅<br><br>Disponibilidad:<br>1️⃣ Jueves 11:00<br>2️⃣ Viernes 16:00<br><br>Elige una opción.</div>
               <div class="msg client">El jueves</div>
               <div class="msg bot">¡Perfecto! Te esperamos el Jueves a las 11:00. ✨</div>`
      },
      {
        title: "TU CENTRO DE MASAJES RELAJA.",
        desc: "Tus clientes reservan su sesión de relajación sin interrumpir tu paz. Automatización total.",
        name: "Zen Masajes",
        chat: `<div class="msg client">Hola, ¿tienen masajes descontracturantes?</div>
               <div class="msg bot">Sí, en Zen Masajes te ayudamos a relajarte 🌿<br><br>Horarios:<br>1️⃣ Mañana 10:00<br>2️⃣ Pasado mañana 18:00<br><br>¿Cuál prefieres?</div>
               <div class="msg client">Mañana a las 10</div>
               <div class="msg bot">¡Excelente elección! Te esperamos mañana a las 10:00. 🧘‍♀️</div>`
      }
    ];

    let currentIndex = 0;
    const titleEl = document.getElementById('dynamic-title');
    const descEl = document.getElementById('dynamic-desc');
    const nameEl = document.getElementById('dynamic-name');
    const chatEl = document.getElementById('dynamic-chat');

    setInterval(() => {
      currentIndex = (currentIndex + 1) % niches.length;
      const next = niches[currentIndex];

      // Transición suave con GSAP
      gsap.to([titleEl, descEl, chatEl], {
        opacity: 0,
        y: 10,
        duration: 0.8,
        onComplete: () => {
          titleEl.innerText = next.title;
          descEl.innerText = next.desc;
          nameEl.innerText = next.name;
          chatEl.innerHTML = next.chat;
          
          gsap.to([titleEl, descEl, chatEl], {
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: "power2.out"
          });
        }
      });
    }, 6000); // Cambia cada 6 segundos (transición lenta)
  }
</script>

<style>
  .hero {
    padding-top: 160px;
    padding-bottom: var(--space-12);
    overflow: hidden;
  }
  .hero-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-8);
  }
  .hero-content {
    flex: 1;
  }
  .hero-content h1 {
    margin: var(--space-4) 0;
    line-height: 1;
  }
  .hero-content p {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  
  /* Phone Mockup */
  .hero-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .phone-mockup {
    width: 340px;
    height: auto;
    background: #FFFFFF;
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-heavy);
    display: flex;
    flex-direction: column;
    transform: rotate(2deg);
  }
  .wa-header {
    background: #000000;
    color: white;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: var(--border-width) solid var(--color-border);
  }
  .wa-avatar {
    width: 40px;
    height: 40px;
    background: var(--color-accent);
    border: 2px solid white;
    border-radius: 50%;
  }
  .wa-info {
    display: flex;
    flex-direction: column;
  }
  .wa-info strong {
    font-size: 1.1rem;
    font-weight: 800;
  }
  .wa-info span {
    font-size: 0.8rem;
    font-weight: 600;
    color: #10B981;
  }
  .wa-chat {
    padding: 20px;
    background: #E0E7FF;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .msg {
    padding: 12px 16px;
    font-size: 0.95rem;
    font-weight: 600;
    border: var(--border-width) solid var(--color-border);
    box-shadow: 4px 4px 0px rgba(0,0,0,0.2);
    width: 85%;
  }
  .msg.client {
    background: #FFFFFF;
    align-self: flex-start;
  }
  .msg.bot {
    background: #FEF08A;
    align-self: flex-end;
  }

  @media (max-width: 992px) {
    .hero-container {
      flex-direction: column;
      text-align: center;
    }
    .hero-ctas {
      justify-content: center;
    }
    .phone-mockup {
      transform: rotate(0);
      margin-top: var(--space-6);
    }
  }
  @media (max-width: 480px) {
    .hero-ctas {
      flex-direction: column;
      width: 100%;
    }
    .hero-ctas .btn {
      width: 100%;
    }
  }
</style>
