---
---
<section class="hero">
  <div class="container hero-container">
    <div class="hero-content gs-reveal">
      <div class="badge">Automatización IA</div>
      <h1>TU <span id="dynamic-business" class="text-accent">TALLER</span><br>AGENDA SOLO.</h1>
      <p>Tus clientes agendan sus horas a través de WhatsApp automáticamente, 24/7, sin esperas. Libérate del teléfono y enfócate en tu negocio.</p>
      <div class="hero-ctas">
        <a href="#demo-vivo" class="btn btn-primary gs-btn">Ver demo en vivo</a>
        <a href="#como-funciona" class="btn btn-secondary gs-btn">Ver cómo funciona</a>
      </div>
    </div>
    
    <div class="hero-visual gs-reveal-right">
      <div class="phone-mockup" id="mockup-container">
        <div class="wa-header">
          <div class="wa-avatar" id="mockup-avatar"></div>
          <div class="wa-info">
            <strong id="mockup-contact">Taller AutoTotal</strong>
            <span>en línea</span>
          </div>
        </div>
        <div class="wa-chat">
          <div class="msg client" id="msg-client-1">Hola, necesito hora para revisión general.</div>
          <div class="msg bot" id="msg-bot-1">¡Hola! Soy el asistente virtual de AutoTotal 🚗<br><br>Horarios disponibles:<br>1️⃣ Mañana 10:00<br>2️⃣ Mañana 15:30<br><br>Responde con el número.</div>
          <div class="msg client" id="msg-client-2">1</div>
          <div class="msg bot" id="msg-bot-2">¡Perfecto! Agenda confirmada ✅.<br>Te recordaremos 2 horas antes.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  const businesses = [
    {
      name: "TALLER",
      contactName: "Taller AutoTotal",
      avatarColor: "var(--color-accent)",
      msg1: "Hola, necesito hora para revisión general.",
      botMsg1: "¡Hola! Soy el asistente virtual de AutoTotal 🚗<br><br>Horarios disponibles:<br>1️⃣ Mañana 10:00<br>2️⃣ Mañana 15:30<br><br>Responde con el número.",
      msg2: "1",
      botMsg2: "¡Perfecto! Agenda confirmada ✅.<br>Te recordaremos 2 horas antes."
    },
    {
      name: "BARBERÍA",
      contactName: "Barbería Classic",
      avatarColor: "#000000",
      msg1: "Buenas, tienen hora para un corte y barba hoy?",
      botMsg1: "¡Hola! Soy el asistente de Barbería Classic 💈<br><br>Horarios de hoy:<br>1️⃣ 16:00 con Diego<br>2️⃣ 18:30 con Felipe<br><br>Responde con el número.",
      msg2: "2",
      botMsg2: "¡Listo! Quedas agendado para las 18:30 ✅.<br>Te esperamos."
    },
    {
      name: "SALÓN DE BELLEZA",
      contactName: "Beauty Studio",
      avatarColor: "#EC4899",
      msg1: "Hola, quiero hacerme las uñas",
      botMsg1: "¡Hola! Asistente de Beauty Studio 💅<br><br>Aquí tienes nuestras opciones:<br>1️⃣ Jueves 10:00<br>2️⃣ Jueves 11:30<br><br>Responde con el número.",
      msg2: "1",
      botMsg2: "¡Super! Agendada el Jueves 10:00 ✅.<br>Te llegará un recordatorio."
    },
    {
      name: "CENTRO DE MASAJES",
      contactName: "Zen Masajes",
      avatarColor: "#10B981",
      msg1: "Hola, necesito un masaje descontracturante",
      botMsg1: "¡Hola! Soy el asistente de Zen Masajes 🌿<br><br>Horarios disponibles:<br>1️⃣ Viernes 17:00<br>2️⃣ Sábado 10:00<br><br>Responde con el número.",
      msg2: "1",
      botMsg2: "¡Perfecto! Agenda confirmada para el Viernes ✅.<br>Nos vemos pronto."
    }
  ];

  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    gsap.from(".badge", { opacity: 0, y: 20, duration: 0.5, delay: 0.1 });
    gsap.from("h1", { opacity: 0, y: 20, duration: 0.5, delay: 0.2 });
    gsap.from(".hero-content p", { opacity: 0, y: 20, duration: 0.5, delay: 0.3 });
    gsap.from(".hero-ctas", { opacity: 0, y: 20, duration: 0.5, delay: 0.4 });
    gsap.from(".phone-mockup", { opacity: 0, x: 20, duration: 0.5, delay: 0.5 });

    let currentIndex = 0;
    const dynamicBusiness = document.getElementById('dynamic-business');
    const mockupAvatar = document.getElementById('mockup-avatar');
    const mockupContact = document.getElementById('mockup-contact');
    const msgClient1 = document.getElementById('msg-client-1');
    const msgBot1 = document.getElementById('msg-bot-1');
    const msgClient2 = document.getElementById('msg-client-2');
    const msgBot2 = document.getElementById('msg-bot-2');
    
    // The elements to fade out/in
    const animatedElements = [
      dynamicBusiness,
      mockupAvatar,
      mockupContact,
      msgClient1,
      msgBot1,
      msgClient2,
      msgBot2
    ];

    setInterval(() => {
      currentIndex = (currentIndex + 1) % businesses.length;
      const nextData = businesses[currentIndex];

      // Fade out slowly
      gsap.to(animatedElements, {
        opacity: 0, 
        duration: 0.8, 
        ease: "power2.inOut",
        onComplete: () => {
          // Change content
          if (dynamicBusiness) dynamicBusiness.textContent = nextData.name;
          if (mockupAvatar) mockupAvatar.style.backgroundColor = nextData.avatarColor;
          if (mockupContact) mockupContact.textContent = nextData.contactName;
          if (msgClient1) msgClient1.innerHTML = nextData.msg1;
          if (msgBot1) msgBot1.innerHTML = nextData.botMsg1;
          if (msgClient2) msgClient2.innerHTML = nextData.msg2;
          if (msgBot2) msgBot2.innerHTML = nextData.botMsg2;

          // Fade back in slowly
          gsap.to(animatedElements, {
            opacity: 1, 
            duration: 0.8,
            ease: "power2.inOut"
          });
        }
      });
    }, 5000); // Wait 5 seconds between changes
  }
</script>

<style>
  .hero {
    padding-top: 160px;
    padding-bottom: var(--space-12);
    overflow: hidden;
  }
  .hero-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-8);
  }
  .hero-content {
    flex: 1;
  }
  .hero-content h1 {
    margin: var(--space-4) 0;
    line-height: 1;
  }
  .text-accent {
    color: var(--color-accent);
    text-shadow: 3px 3px 0px #000000;
  }
  .hero-content p {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  
  /* Phone Mockup */
  .hero-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .phone-mockup {
    width: 340px;
    height: auto;
    background: #FFFFFF;
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-heavy);
    display: flex;
    flex-direction: column;
    transform: rotate(2deg);
  }
  .wa-header {
    background: #000000;
    color: white;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: var(--border-width) solid var(--color-border);
  }
  .wa-avatar {
    width: 40px;
    height: 40px;
    background: var(--color-accent);
    border: 2px solid white;
    border-radius: 50%;
  }
  .wa-info {
    display: flex;
    flex-direction: column;
  }
  .wa-info strong {
    font-size: 1.1rem;
    font-weight: 800;
  }
  .wa-info span {
    font-size: 0.8rem;
    font-weight: 600;
    color: #10B981;
  }
  .wa-chat {
    padding: 20px;
    background: #E0E7FF;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 400px;
  }
  .msg {
    padding: 12px 16px;
    font-size: 0.95rem;
    font-weight: 600;
    border: var(--border-width) solid var(--color-border);
    box-shadow: 4px 4px 0px rgba(0,0,0,0.2);
    width: 85%;
  }
  .msg.client {
    background: #FFFFFF;
    align-self: flex-start;
  }
  .msg.bot {
    background: #FEF08A;
    align-self: flex-end;
  }

  @media (max-width: 992px) {
    .hero-container {
      flex-direction: column;
      text-align: center;
    }
    .hero-ctas {
      justify-content: center;
    }
    .phone-mockup {
      transform: rotate(0);
      margin-top: var(--space-6);
    }
  }
  @media (max-width: 480px) {
    .hero-ctas {
      flex-direction: column;
      width: 100%;
    }
    .hero-ctas .btn {
      width: 100%;
    }
  }
</style>
