---
---
<section class="comparison-section">
  <div class="container container-narrow text-center gs-comp-header" style="margin-bottom:4rem;">
    <h2>Nosotros vs Los Demás</h2>
  </div>
  
  <div class="container">
    <div class="brutalist-card wrapper-table gs-table">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>COMPARATIVA</th>
            <th class="manual">HAZLO TÚ (CAOS)</th>
            <th class="competitor">AGENDAPRO / OTROS</th>
            <th class="highlight">FUTURA NODES ⚡</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="row-label" data-label="COMPARATIVA">Modelo de cobro</td>
            <td data-label="HAZLO TÚ (CAOS)">Tu tiempo perdido</td>
            <td data-label="AGENDAPRO / OTROS">Cobras por profesional</td>
            <td class="highlight strong" data-label="FUTURA NODES">Tarifa Plana Ilimitada</td>
          </tr>
          <tr>
            <td class="row-label" data-label="COMPARATIVA">WhatsApp Automatizado</td>
            <td data-label="HAZLO TÚ (CAOS)">Respondes a mano</td>
            <td data-label="AGENDAPRO / OTROS">Muy básico / Caro</td>
            <td class="highlight" data-label="FUTURA NODES">SÍ, Vende 24/7</td>
          </tr>
          <tr>
            <td class="row-label" data-label="COMPARATIVA">Propiedad de datos</td>
            <td data-label="HAZLO TÚ (CAOS)">Tu libreta</td>
            <td data-label="AGENDAPRO / OTROS">Secuestrados por la App</td>
            <td class="highlight" data-label="FUTURA NODES">100% TUYOS (Exportable)</td>
          </tr>
          <tr>
            <td class="row-label" data-label="COMPARATIVA">Presencia Web</td>
            <td data-label="HAZLO TÚ (CAOS)">Solo redes sociales</td>
            <td data-label="AGENDAPRO / OTROS">Perfil genérico</td>
            <td class="highlight" data-label="FUTURA NODES">Sitio Web Profesional Propio</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison-section {
    background-color: var(--color-bg);
  }
  .wrapper-table {
    overflow-x: auto;
    padding: 0;
  }
  .comparison-table {
    width: 100%;
    min-width: 700px;
    border-collapse: collapse;
    background: white;
    text-align: left;
  }
  .comparison-table th, .comparison-table td {
    padding: 1.5rem;
    border-bottom: var(--border-width) solid var(--color-border);
    border-right: var(--border-width) solid var(--color-border);
  }
  .comparison-table th:last-child, .comparison-table td:last-child {
    border-right: none;
  }
  .comparison-table tr:last-child td {
    border-bottom: none;
  }
  .comparison-table th {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--color-primary);
    background-color: var(--color-surface-alt);
  }
  .row-label {
    font-weight: 800;
    color: var(--color-primary);
    font-size: 1.125rem;
  }
  .highlight {
    background-color: var(--color-accent);
    color: white !important;
  }
  .comparison-table th.highlight {
    background-color: var(--color-primary);
    color: white;
  }
  .highlight.strong {
    font-weight: 900;
  }

  @media (max-width: 768px) {
    .wrapper-table {
      padding: 0.5rem;
      background: transparent;
      border: none;
      box-shadow: none;
    }
    .comparison-table {
      display: grid;
      gap: 1.5rem;
      min-width: unset;
    }
    .comparison-table thead {
      display: none;
    }
    .comparison-table tbody {
      display: contents;
    }
    .comparison-table tr {
      display: grid;
      grid-template-columns: 1fr;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 4px 4px 0px #000;
      background: white;
    }
    .comparison-table td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem;
      border-bottom: 1px solid var(--color-border);
      border-right: none;
      font-size: 0.95rem;
      background-color: var(--color-primary) !important;
      color: white !important;
    }
    .comparison-table td::before {
      content: attr(data-label);
      font-weight: 900;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-right: 1rem;
      flex-shrink: 0;
    }
    .comparison-table td:last-child {
      border-bottom: none;
      background-color: var(--color-primary);
      color: white;
      font-weight: 700;
      border: var(--border-width) solid white;
    }
    .comparison-table tr {
      background-color: var(--color-primary);
    }
    .comparison-table td {
      background-color: white;
      color: var(--color-primary);
    }
  }
</style>
