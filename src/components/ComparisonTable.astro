---
---
<section class="comparison-section">
  <div class="container container-narrow text-center gs-comp-header" style="margin-bottom:4rem;">
    <h2>Nosotros vs Los Demás</h2>
  </div>
  
  <div class="container">
    <div class="brutalist-card wrapper-table gs-table">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>CARACTERÍSTICA</th>
            <th class="manual">MANUAL</th>
            <th class="competitor">OTRO SOFTWARE</th>
            <th class="highlight">FUTURA NODES</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="row-label">Modelo de cobro</td>
            <td>Tu tiempo</td>
            <td>Por Empleado</td>
            <td class="highlight strong">Tarifa Plana</td>
          </tr>
          <tr>
            <td class="row-label">Bot de WhatsApp</td>
            <td>NO</td>
            <td>Básico / Cobro extra</td>
            <td class="highlight">SÍ, Inteligente</td>
          </tr>
          <tr>
            <td class="row-label">Propiedad de base</td>
            <td>SÍ</td>
            <td>De la App</td>
            <td class="highlight">100% TUYA</td>
          </tr>
          <tr>
            <td class="row-label">Web Propia</td>
            <td>NO</td>
            <td>Perfil Genérico</td>
            <td class="highlight">Sitio Brutal Propio</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison-section {
    background-color: var(--color-bg);
  }
  .wrapper-table {
    overflow-x: auto;
    padding: 0;
  }
  .comparison-table {
    width: 100%;
    min-width: 700px;
    border-collapse: collapse;
    background: white;
    text-align: left;
  }
  .comparison-table th, .comparison-table td {
    padding: 1.5rem;
    border-bottom: var(--border-width) solid var(--color-border);
    border-right: var(--border-width) solid var(--color-border);
  }
  .comparison-table th:last-child, .comparison-table td:last-child {
    border-right: none;
  }
  .comparison-table tr:last-child td {
    border-bottom: none;
  }
  .comparison-table th {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--color-primary);
    background-color: var(--color-surface-alt);
  }
  .row-label {
    font-weight: 800;
    color: var(--color-primary);
    font-size: 1.125rem;
  }
  .highlight {
    background-color: var(--color-accent);
    color: white !important;
  }
  .comparison-table th.highlight {
    background-color: var(--color-primary);
    color: white;
  }
  .highlight.strong {
    font-weight: 900;
  }
</style>
