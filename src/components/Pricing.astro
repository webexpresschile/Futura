---
---
<section class="pricing-section" id="precios">
  <div class="container container-narrow text-center gs-pricing-header" style="margin-bottom: 4rem;">
    <h2>Precios Agresivos</h2>
    <p>Sin costos ocultos. Crecimiento sin frenos.</p>
  </div>
  
  <div class="container pricing-container">
    <div class="brutalist-card gs-pricing pricing-card">
      <div class="card-header">
        <h3>PLAN FULL</h3>
        <div class="price">
          <span class="currency">$</span><span class="amount">120k</span><span class="period">/mes</span>
        </div>
        <p class="setup-fee">+ $100k (Setup)</p>
      </div>
      <div class="card-body">
        <ul>
          <li><strong>✓</strong> Bot IA Inagotable</li>
          <li><strong>✓</strong> Sitio Web Brutalista</li>
          <li><strong>✓</strong> Recordatorios 100% Automáticos</li>
          <li><strong>✓</strong> Agenda Ilimitada</li>
        </ul>
        <a href="#contacto" class="btn btn-secondary full-width">AGENDAR DEMO</a>
      </div>
    </div>
    
    <div class="brutalist-card gs-pricing pricing-card card-blue">
      <div class="badge-wrapper">
        <span class="badge">LANZAMIENTO</span>
      </div>
      <div class="card-header">
        <h3 style="border-color: white;">LICITACIÓN</h3>
        <div class="price">
          <span class="currency">$</span><span class="amount" style="color:white;">69k</span><span class="period" style="color:white;">/mes</span>
        </div>
        <p class="setup-fee" style="color:white;">+ $50k (Setup)</p>
      </div>
      <div class="card-body">
        <ul>
          <li><strong>✓ TODO EL PLAN FULL</strong></li>
          <li><strong>✓ Precio asegurado de por vida</strong></li>
          <li><strong>✓ Prioridad extrema en soporte</strong></li>
          <li><strong>✓ 20 Cupos (Llenándose rápido)</strong></li>
        </ul>
        <a href="#contacto" class="btn btn-secondary full-width" style="background:#FEF08A; border-color:black;">QUIERO ESTE PLAN</a>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    background-color: var(--color-surface);
  }
  .pricing-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto;
  }
  .pricing-card {
    display: flex;
    flex-direction: column;
    position: relative;
    padding: 3rem 2rem;
  }
  .card-blue {
    background-color: var(--color-accent);
    color: white;
  }
  .card-blue p, .card-blue li {
    color: white;
  }
  .badge-wrapper {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    text-align: center;
  }
  .card-header {
    border-bottom: var(--border-width) solid var(--color-border);
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    text-align: left;
  }
  .card-header h3 {
    font-size: 1.5rem;
    color: var(--color-primary);
  }
  .card-blue .card-header h3 {
    color: white;
  }
  .price {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 900;
    line-height: 1;
    margin: 1rem 0;
  }
  .currency {
    font-size: 2rem;
    vertical-align: top;
    line-height: 2;
  }
  .period {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .setup-fee {
    font-weight: 700;
    text-transform: uppercase;
  }
  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .card-body ul {
    margin-bottom: 2rem;
  }
  .card-body li {
    padding: 0.5rem 0;
    font-size: 1.125rem;
    font-weight: 600;
  }
  @media (max-width: 768px) {
    .pricing-container {
      grid-template-columns: 1fr;
    }
  }
</style>
