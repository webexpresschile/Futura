---
---
<section class="testimonial-section">
  <div class="container container-narrow">
    <div class="testimonial-content gs-test">
      <div class="quote-icon">"</div>
      <blockquote>
        Antes de Futura Nodes, perdía al menos 3 o 4 clientes por semana porque me escribían cuando estaba debajo de un auto y les respondía horas después. Ahora el taller se llena solo, y yo no toco el teléfono en todo el día.
      </blockquote>
      <div class="author-info">
        <strong>Roberto Cárdenas</strong>
        <span>Dueño de Serviteca R&C — Maipú, Santiago</span>
      </div>
      
      <div class="metrics">
        <div class="metric">
          <span class="metric-value">+3</span>
          <span class="metric-label">citas recuperadas en la primera semana</span>
        </div>
        <div class="metric">
          <span class="metric-value">47</span>
          <span class="metric-label">reseñas orgánicas en Google en 2 meses</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    gsap.from(".gs-test", {
      scrollTrigger: { trigger: ".testimonial-section", start: "top 80%" },
      y: 40, opacity: 0, duration: 1
    });
  }
</script>

<style>
  .testimonial-section {
    background-color: var(--color-bg);
  }
  .container-narrow {
    max-width: 900px;
    text-align: center;
  }
  .testimonial-content {
    background: var(--color-surface);
    padding: var(--space-8);
    border-radius: var(--radius-md);
    position: relative;
    border: 1px solid var(--color-border);
  }
  .quote-icon {
    font-family: var(--font-display);
    font-size: 6rem;
    color: var(--color-accent);
    line-height: 0;
    margin-bottom: var(--space-2);
    opacity: 0.2;
    position: absolute;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
  }
  blockquote {
    font-size: 1.5rem;
    font-family: var(--font-display);
    color: var(--color-primary);
    line-height: 1.4;
    margin: var(--space-4) 0;
    position: relative;
    z-index: 1;
  }
  .author-info {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--space-6);
  }
  .author-info strong {
    font-size: 1.125rem;
    color: var(--color-primary);
  }
  .author-info span {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }
  .metrics {
    display: flex;
    justify-content: center;
    gap: var(--space-6);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }
  .metric {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .metric-value {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-success);
    line-height: 1;
  }
  .metric-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    max-width: 200px;
    margin-top: var(--space-1);
  }

  @media (max-width: 768px) {
    .testimonial-content {
      padding: var(--space-6) var(--space-4);
    }
    blockquote {
      font-size: 1.25rem;
    }
    .metrics {
      flex-direction: column;
      gap: var(--space-4);
    }
  }
</style>
