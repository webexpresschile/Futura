<section class="final-cta" id="demo">
  <div class="container">
    <div class="cta-box">
      <h2>TU COMPETENCIA YA AUTOMATIZÓ.<br>¿QUÉ ESPERAS TÚ?</h2>
      <a href="https://wa.me/56973027813?text=Hola,%20quiero%20mi%20demo%20de%20Futura" class="btn btn-primary cta-huge">AGENDA DEMO AHORA</a>
    </div>
  </div>
</section>

<style>
  .final-cta {
    background-color: var(--color-bg);
    padding: 6rem 0;
    border-top: var(--border-width) solid var(--color-border);
  }
  .cta-box {
    background-color: white;
    border: var(--border-width) solid var(--color-border);
    box-shadow: 8px 8px 0px #000;
    padding: 4rem 2rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }
  .final-cta h2 {
    color: var(--color-primary);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 3rem;
  }
  .cta-huge {
    font-size: 1.5rem;
    padding: 1.25rem 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    background-color: var(--color-accent);
    color: white;
    border: var(--border-width) solid var(--color-border);
    box-shadow: 4px 4px 0px #000;
    transition: all 0.2s ease;
  }
  .cta-huge:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px #000;
  }
  @media (max-width: 600px) {
    .cta-box {
      padding: 2rem 1rem;
    }
    .cta-huge {
      font-size: 1.1rem;
      padding: 1rem 1.5rem;
      width: 100%;
      display: block;
    }
  }
</style>
