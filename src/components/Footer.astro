<footer class="footer" id="contacto">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">FUTURA NODES</h2>
        <p style="color: black; font-weight:700;">Tú trabajas, nosotros agendamos.</p>
      </div>
      
      <div class="footer-links">
        <a href="#funciones">FUNCIONES</a>
        <a href="#precios">PRECIOS</a>
        <a href="#demo">DEMO</a>
        <a href="#">TÉRMINOS</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: white;
    padding: 4rem 0;
  }
  .footer-grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-sm);
    padding: 3rem;
  }
  .footer-links {
    display: flex;
    gap: 2rem;
  }
  .footer-links a {
    font-weight: 900;
    text-transform: uppercase;
    font-size: 1.25rem;
  }
  .footer-links a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }
  @media (max-width: 768px) {
    .footer-grid {
      flex-direction: column;
      gap: 3rem;
      text-align: center;
      padding: 2rem;
    }
    .footer-links {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
