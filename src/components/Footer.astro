---
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/logo.png" alt="Futura Nodes" style="height: 48px; margin-bottom: 1rem; filter: brightness(0) invert(1);" />
        <p>Agencia Digital. Impulsamos tu negocio con Diseño Web, Tiendas Online y Soluciones con IA.</p>
      </div>
      
      <div class="footer-links-col">
        <h3>Servicios</h3>
        <a href="/servicios#diseno-web">Diseño Web</a>
        <a href="/servicios#ia">Sistemas con IA</a>
        <a href="/servicios#ecommerce">Tienda Nube</a>
      </div>
      
      <div class="footer-links-col">
        <h3>Agencia</h3>
        <a href="/nosotros">Nosotros</a>
        <a href="/blog">Blog</a>
        <a href="/contacto">Contacto</a>
      </div>
      
      <div class="footer-links-col">
        <h3>Síguenos</h3>
        <div class="social-links">
          <a href="#" aria-label="LinkedIn">LinkedIn</a>
          <a href="#" aria-label="Instagram">Instagram</a>
          <a href="#" aria-label="Twitter">Twitter</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Futura Nodes. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-dark);
    color: var(--color-text-inverse);
    padding: var(--space-8) 0 var(--space-4) 0;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }
  
  .footer-brand h2 {
    color: var(--color-text-inverse);
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  
  .footer-brand p {
    color: rgba(255,255,255,0.7);
    max-width: 300px;
    font-size: 1rem;
  }
  
  .footer-links-col h3 {
    color: var(--color-text-inverse);
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
  }
  
  .footer-links-col a, .social-links a {
    display: block;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.75rem;
    font-size: 1rem;
  }
  
  .footer-links-col a:hover, .social-links a:hover {
    color: var(--color-secondary);
    transform: translateX(4px);
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 2rem;
    text-align: center;
  }
  
  .footer-bottom p {
    color: rgba(255,255,255,0.5);
    font-size: 0.875rem;
    margin: 0;
  }
  
  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }
  
  @media (max-width: 576px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
